<?xml version="1.0" encoding="utf-8"?>
<RunSettings>
  <RunConfiguration>
    <MaxCpuCount>4</MaxCpuCount>
  </RunConfiguration>
  <!--
    Code coverage is intentionally NOT configured here. The XPlat Code Coverage
    data collector requires the Coverlet.Collector package to be referenced by
    the test projects; none of them reference it, so enabling it produced
    "Unable to find a datacollector with friendly name 'XPlat code coverage'"
    warnings on every run without ever producing coverage data.

    To re-enable coverage:
      1. Add <PackageReference Include="Coverlet.Collector" Version="6.0.2" />
         to each unit/integration/concurrency test project.
      2. Restore the <DataCollectionRunSettings> block below.
  -->
  <!--
  <DataCollectionRunSettings>
    <DataCollectors>
      <DataCollector friendlyName="XPlat code coverage">
        <Configuration>
          <Format>cobertura</Format>
          <Exclude>[Eventy.Testing.Foundation]*,[*.Tests]*,[xunit*]*</Exclude>
          <IncludeRecursive>true</IncludeRecursive>
        </Configuration>
      </DataCollector>
    </DataCollectors>
  </DataCollectionRunSettings>
  -->
</RunSettings>
